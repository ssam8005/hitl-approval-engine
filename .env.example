# ── FastAPI Service ─────────────────────────────────────────────────────────
API_SECRET_KEY=generate-a-long-random-secret-here
SERVICE_PORT=8080
ENVIRONMENT=production          # production | development

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=             # from @BotFather
TELEGRAM_CHAT_ID=               # your Telegram user or group ID
TELEGRAM_MODE=polling           # polling (dev) | webhook (prod)
TELEGRAM_WEBHOOK_URL=           # required if TELEGRAM_MODE=webhook

# ── Approval Logic ────────────────────────────────────────────────────────────
AUTO_APPROVE_SCORE_THRESHOLD=85     # leads >= this auto-approve without review
AUTO_REJECT_SCORE_THRESHOLD=30      # leads <= this auto-reject silently
APPROVAL_TTL_HOURS=24               # pending approvals expire after N hours
DEFAULT_APPROVAL_ACTION=reject      # action on expiry: approve | reject

# ── Downstream Webhook (n8n / Zapier / Make) ──────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/hitl-approved
N8N_WEBHOOK_SECRET=             # shared secret — sent as X-Webhook-Secret header
WEBHOOK_TIMEOUT_SECONDS=10

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hitl_engine.db   # swap to postgresql://... for production

# ── Audit ─────────────────────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_RETENTION_DAYS=90
